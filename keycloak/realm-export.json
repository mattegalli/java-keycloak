{
  "realm": "notes-realm",
  "enabled": true,
  "displayName": "Personal Notes",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,

  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard user — can manage their own notes"
      },
      {
        "name": "admin",
        "description": "Administrator — can view all notes"
      }
    ]
  },

  "clients": [
    {
      "clientId": "notes-backend",
      "name": "Notes Backend",
      "description": "Spring Boot resource server — validates JWTs (Phase 3)",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "notes-backend-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "bearerOnly": true
    },
    {
      "clientId": "notes-frontend",
      "name": "Notes Frontend",
      "description": "Vanilla JS SPA — Authorization Code + PKCE (Phase 4)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],

  "users": [
    {
      "username": "alice",
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Smith",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "bob",
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Jones",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "admin",
      "email": "admin@example.com",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"]
    }
  ]
}
